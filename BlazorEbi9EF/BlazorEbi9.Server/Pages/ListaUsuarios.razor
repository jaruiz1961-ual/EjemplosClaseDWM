@page "/ListaUsuarios"
@using BlazorEbi9.Data.DataBase
@using BlazorEbi9.Model.Entidades
@using BlazorEbi9.Model.IServices
@using BlazorEbi9.Model.TenantService
@using Microsoft.EntityFrameworkCore
@inject ITenantService Service
@inject IDbContextFactory<SqLiteDbContext> Factory



<h1>ListaUsuarios</h1>

<div>
    <a href="/DetalleUsuario"><i>Añadir usuario</i></a>
</div>

@if (users == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>UserName</th>
                <th>Codigo</th>
                <th>Nivel</th>
                <th>Password</th>
                <th>Tenant</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in users)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.UserName</td>
                    <td>@user.Codigo</td>
                    <td>@user.NivelAcceso</td>
                    <td>@user.Password</td>
                    <td>@user.TenantId</td>
                    <td><a href="/DetalleUsuario/@user.Id"><i>Edit</i></a></td>
                    <td><a href="/DeleteUsuario/@user.Id"><i>Del</i></a></td>
                </tr>
            }
        </tbody>
    </table>
}
@code {
    private List<UsuarioSet> users;
    private IUsuarioServiceAsync UsuarioService;
    private bool _disposed;

    protected override async Task OnInitializedAsync()
    {
        // Suscribirse una vez al evento
        Service.OnTenantChanged += TenantChangedHandler;

        await LoadUsersAsync();
    }

    private async void TenantChangedHandler(object? sender, EventArgs e)
    {
        // handler async-void está bien para eventos; crea su propio contexto
        await LoadUsersAsync();
        StateHasChanged();
    }

    private async Task LoadUsersAsync()
    {
        // Crear y disponer el DbContext por cada operación.
        await using var context = await Factory.CreateDbContextAsync();

        // Asignar el tenant a la instancia del contexto (evita inyectarlo en el ctor).
        if (context is SqLiteDbContext sqliteCtx)
        {
            sqliteCtx.CurrentTenant = Service.Tenant;
        }

        using var uow = new UnitOfWorkAsync<SqLiteDbContext>(context as SqLiteDbContext);
        UsuarioService = new UsuarioServiceAsync(uow);
        users = await UsuarioService.FindAllAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_disposed) return;
        _disposed = true;
        Service.OnTenantChanged -= TenantChangedHandler;

        // Si UsuarioService/uow necesita DisposeAsync, dispón aquí. Ejemplo:
        if (UsuarioService is IAsyncDisposable asyncDisp)
        {
            await asyncDisp.DisposeAsync();
        }
        else if (UsuarioService is IDisposable disp)
        {
            disp.Dispose();
        }
    }
}
}

