@page "/DeleteUsuario"
@page "/DeleteUsuario/{Id:int}"
@using BlazorEbi9.Data.DataBase
@using BlazorEbi9.Model.TenantService
@inject NavigationManager nav
@inject ITenantService Service
@inject BlazorEbi9.Data.DataBase.ITenantDbContextFactory Factory
<h3>Eliminar Usuario</h3>
<p styp="color:red;text-align:center">¿Estas seguro ?</p>

@*<EditForm Model="@usuarioSet" />*@
<table class="table">
    <tr>
        <td>Codigo:</td>
        <td><input class="form-control" col-sm-4 type="text" @bind="usuarioSet.Codigo" /> </td>
    </tr>
    <tr>
        <td>UserName:</td>
        <td><input class="form-control" col-sm-4 type="text" @bind="usuarioSet.UserName" /> </td>
    </tr>


    <tr>
        <td>NivelAcceso:</td>
        <td><input class="form-control" col-sm-4 type="text" @bind="usuarioSet.NivelAcceso" /> </td>
    </tr>

    <tr>
        <td>Password:</td>
        <td><input class="form-control" col-sm-4 type="text" @bind="usuarioSet.Password" /> </td>
    </tr>

    <tr>
        <td>Password:</td>
        <td><input class="form-control" col-sm-4 type="text" @bind="usuarioSet.email" /> </td>
    </tr>

    <tr>
        <td colspan="2" style="text-align:center">
            <input type="submit" value="Delete" @onclick="Delete" />
            <input type="button" value="Cancel" @onclick="Cancel" />

        </td>
    </tr>

</table>
@code {
    [Parameter] public int Id { get; set; }

    private UsuarioSet usuarioSet = new UsuarioSet();
    UsuarioServiceAsync usuarioService;

    protected override async Task OnInitializedAsync()
    {
        // Suscribir a cambios de tenant -> recargar
        Service.OnTenantChanged += TenantChangedHandler;

        await LoadUserAsync();
    }

    private async void TenantChangedHandler(object? sender, EventArgs e)
    {
        await LoadUserAsync();
        StateHasChanged();
    }

    private async Task LoadUserAsync()
    {
        // Crear y disponer contexto/UoW/servicio por operación
        var context = await Factory.CreateDbContextAsync();
        var uow = new UnitOfWorkAsync<SqLiteDbContext>(context);
        usuarioService = new UsuarioServiceAsync(uow);

        if (Id != 0)
        {
            var user = await usuarioService.FindIdAsync(Id);
            if (user != null) usuarioSet = user;
        }

        // asegurar tenant correcto en el modelo para el formulario
        usuarioSet.TenantId = Service.Tenant;
    }

    protected async Task Delete()
    {
        await usuarioService.DeleteIdAsync(Id);
        nav.NavigateTo("/ListaUsuarios");
    }

    protected void Cancel()
    {
        nav.NavigateTo("/ListaUsuarios");
    }

    protected async Task SaveUsuario()
    {
        // Crear contexto/UoW/servicio aquí también (no reutilizar uno creado antes)
        // await using var context = await Factory.CreateDbContextAsync();
        // using var uow = new UnitOfWorkAsync<SqLiteDbContext>(context);
        // var usuarioService = new UsuarioServiceAsync(uow);

        await usuarioService.SaveUserAsyncTenant(usuarioSet, Service);
        nav.NavigateTo("/ListaUsuarios");
    }

   

    public async ValueTask DisposeAsync()
    {
        Service.OnTenantChanged -= TenantChangedHandler;
        if (usuarioService is IAsyncDisposable asyncDisp)
        {
            await asyncDisp.DisposeAsync();
        }
        else if (usuarioService is IDisposable disp)
        {
            disp.Dispose();
        }
    }

    

}

